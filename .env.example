# Memory MCP Server Configuration
# All settings are optional - defaults work out of the box

# Data directory for DuckDB files (default: ~/.memory-mcp)
# MEMORY_MCP_DATA_DIR=~/.memory-mcp

# Embedding model (default: all-MiniLM-L6-v2)
# MEMORY_MCP_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Embedding dimensions (default: 384, must match model)
# MEMORY_MCP_EMBEDDING_DIM=384

# Max concurrent DuckDB connections (default: 5)
# MEMORY_MCP_MAX_CONNECTIONS=5

# Rules cache TTL in seconds (default: 60)
# MEMORY_MCP_RULES_CACHE_TTL=60
